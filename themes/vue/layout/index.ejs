    <a class="social-icon" href="https://github.com/ZZXM" target="_blank" rel="noopener">
      <%- partial('icons/github') %>
    </a>
    <a class="social-icon" href="https://blog.csdn.net/zzxm_l/article/details/103926967" target="_blank" rel="noopener">
